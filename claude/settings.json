{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "mcp__archon",
      "mcp__context7",
      "mcp__next-devtools",
      "mcp__sibyl",
      "Bash(sibyl:*)"
    ],
    "deny": [],
    "ask": [
      "Bash(kubectl delete:*)",
      "Bash(kubectl exec:*)",
      "Bash(argocd:*)",
      "Bash(rm:*)",
      "Bash(git push:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/bliss/.claude/hooks/sibyl/session-start.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/bliss/.claude/hooks/sibyl/session-start.py",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/bliss/.claude/hooks/sibyl/user-prompt-submit.py",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "hyperskills@hyperb1iss": true,
    "astral@astral-sh": true,
    "moonrepo@hyperb1iss-skills": true,
    "supabase@claude-plugins-official": true,
    "terraform@claude-plugins-official": true,
    "netlify-skills@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "hyperb1iss": {
      "source": {
        "source": "github",
        "repo": "hyperb1iss/hyperskills"
      }
    },
    "hyperb1iss-skills": {
      "source": {
        "source": "github",
        "repo": "hyperb1iss/moonrepo-skill"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "model": "opus[1m]"
}
